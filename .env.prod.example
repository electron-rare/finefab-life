# FineFab production environment template for Tower
# Fill all placeholders before deployment. Do not commit real secrets.

ENV=production
COMPOSE_PROJECT_NAME=finefab-life

# Public URLs
LIFE_WEB_PUBLIC_URL=https://life.saillant.cc
LIFE_API_PUBLIC_URL=https://api.saillant.cc
LIFE_WEB_PUBLIC_URL_SECONDARY=https://life.lelectronrare.fr
LIFE_API_PUBLIC_URL_SECONDARY=https://api.lelectronrare.fr
YIACAD_PUBLIC_URL=https://yiacad.saillant.cc
AUTH_PUBLIC_URL=https://auth.saillant.cc

# Internal service URLs
LIFE_CORE_URL=http://life-core:8000
LIFE_REBORN_URL=http://life-reborn:3210
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
LANGFUSE_HOST=http://langfuse:3000

# LLM routing
VLLM_BASE_URL=http://192.168.0.160:11436
VLLM_MODELS=openai/qwen-14b-awq
OLLAMA_URL=http://host.docker.internal:11435

# API access and CORS
ALLOWED_ORIGINS=https://life.saillant.cc,https://api.saillant.cc,https://yiacad.saillant.cc
API_BEARER_TOKEN=replace-me

# Domain exposure policy (Traefik host allowlist)
# Default: expose only saillant.cc hostnames.
# To include lelectronrare.fr, set rules explicitly, for example:
# TRAEFIK_WEB_HOST_RULE=Host(`life.saillant.cc`) || Host(`life.lelectronrare.fr`)
# TRAEFIK_API_HOST_RULE=Host(`api.saillant.cc`) || Host(`api.lelectronrare.fr`)
TRAEFIK_WEB_HOST_RULE=Host(`life.saillant.cc`)
TRAEFIK_API_HOST_RULE=Host(`api.saillant.cc`)
TRAEFIK_LANGFUSE_HOST_RULE=Host(`langfuse.saillant.cc`)
TRAEFIK_DASHBOARD_HOST_RULE=Host(`traefik.local`)

# Cloud providers
ANTHROPIC_API_KEY=replace-me
OPENAI_API_KEY=replace-me
MISTRAL_API_KEY=replace-me
GOOGLE_API_KEY=replace-me

# Auth / SSO
KEYCLOAK_URL=https://auth.saillant.cc
KEYCLOAK_REALM=replace-me
KEYCLOAK_CLIENT_ID=replace-me
KEYCLOAK_CLIENT_SECRET=replace-me

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=finefab-life
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me

# Traefik / ingress
TRAEFIK_ACME_EMAIL=replace-me@example.com
CLOUDFLARE_AUTH_EMAIL=replace-me@example.com
CLOUDFLARE_API_KEY=replace-me
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=replace-me
# Network exposure hardening: use 127.0.0.1 to avoid LAN/public bind.
# Set to a specific host IP only if you explicitly need direct LAN ingress.
TRAEFIK_BIND_IP=127.0.0.1

# Health-check behavior
CHECK_SECONDARY_DOMAIN=0

# Optional persistence / admin
FORGEJO_ROOT_URL=https://git.saillant.cc
FORGEJO_ADMIN_USER=replace-me
FORGEJO_ADMIN_PASSWORD=replace-me

# Notes
# - Copy to .env.prod on Tower and set permissions to 600.
# - Prefer a secret manager if available.
# - Keep domains and ports aligned with docker-compose production.
