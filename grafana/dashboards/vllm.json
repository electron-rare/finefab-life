{
  "uid": "vllm-kxkm",
  "title": "vLLM — KXKM-AI (Qwen 32B + LoRA)",
  "tags": ["vllm", "gpu", "llm"],
  "timezone": "browser",
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requests Running",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "finefab_vllm:num_requests_running{job=\"vllm\"}", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 10, "color": "red"}]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Requests Waiting",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "finefab_vllm:num_requests_waiting{job=\"vllm\"}", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 2, "color": "yellow"}, {"value": 5, "color": "red"}]}}}
    },
    {
      "id": 3, "type": "gauge", "title": "KV Cache Usage",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "finefab_vllm:kv_cache_usage_perc{job=\"vllm\"}", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.7, "color": "yellow"}, {"value": 0.9, "color": "red"}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Total Requests",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "finefab_vllm:request_success_total{job=\"vllm\"}", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "blue"}]}}}
    },
    {
      "id": 5, "type": "stat", "title": "Prefix Cache Hit Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "rate(finefab_vllm:prefix_cache_hits_total{job=\"vllm\"}[5m]) / (rate(finefab_vllm:prefix_cache_queries_total{job=\"vllm\"}[5m]) > 0)", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 0.3, "color": "yellow"}, {"value": 0.6, "color": "green"}]}}}
    },
    {
      "id": 6, "type": "stat", "title": "Preemptions/s",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "rate(finefab_vllm:num_preemptions_total{job=\"vllm\"}[5m])", "refId": "A"}],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "red"}]}}}
    },
    {
      "id": 10, "type": "timeseries", "title": "Token Throughput (tokens/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(finefab_vllm:prompt_tokens_total{job=\"vllm\"}[1m])", "refId": "A", "legendFormat": "Prompt tokens/s"},
        {"expr": "rate(finefab_vllm:generation_tokens_total{job=\"vllm\"}[1m])", "refId": "B", "legendFormat": "Generation tokens/s"}
      ],
      "datasource": {"uid": "prometheus"}
    },
    {
      "id": 11, "type": "timeseries", "title": "E2E Request Latency (p50 / p95 / p99)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:e2e_request_latency_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(finefab_vllm:e2e_request_latency_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "B", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(finefab_vllm:e2e_request_latency_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "C", "legendFormat": "p99"}
      ],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 12, "type": "timeseries", "title": "Time to First Token (TTFT)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:time_to_first_token_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "A", "legendFormat": "TTFT p50"},
        {"expr": "histogram_quantile(0.95, rate(finefab_vllm:time_to_first_token_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "B", "legendFormat": "TTFT p95"}
      ],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 13, "type": "timeseries", "title": "KV Cache + Request Queue",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "finefab_vllm:kv_cache_usage_perc{job=\"vllm\"}", "refId": "A", "legendFormat": "KV Cache %"},
        {"expr": "finefab_vllm:num_requests_running{job=\"vllm\"}", "refId": "B", "legendFormat": "Running"},
        {"expr": "finefab_vllm:num_requests_waiting{job=\"vllm\"}", "refId": "C", "legendFormat": "Waiting"}
      ],
      "datasource": {"uid": "prometheus"}
    },
    {
      "id": 14, "type": "timeseries", "title": "Inter-Token Latency",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:inter_token_latency_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "A", "legendFormat": "ITL p50"},
        {"expr": "histogram_quantile(0.95, rate(finefab_vllm:inter_token_latency_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "B", "legendFormat": "ITL p95"}
      ],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 15, "type": "timeseries", "title": "Request Phases (Prefill / Decode / Queue)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:request_prefill_time_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "A", "legendFormat": "Prefill p50"},
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:request_decode_time_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "B", "legendFormat": "Decode p50"},
        {"expr": "histogram_quantile(0.5, rate(finefab_vllm:request_queue_time_seconds_bucket{job=\"vllm\"}[5m]))", "refId": "C", "legendFormat": "Queue p50"}
      ],
      "datasource": {"uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
